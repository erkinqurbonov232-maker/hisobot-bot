import os
import json
import gspread
from google.oauth2.service_account import Credentials
from telegram import Update
from telegram.ext import Application, CommandHandler, ContextTypes
from datetime import datetime # 1. Bu shart

# 1. TOKEN va GOOGLE ni olish
TOKEN = os.getenv("TELEGRAM_TOKEN")
print(f"TOKEN VALUE: {TOKEN}") # SHUNI QO'SH
creds_json = os.getenv("GOOGLE_CREDENTIALS_JSON")
creds_dict = json.loads(creds_json)

scope = ["https://spreadsheets.google.com/feeds", "https://www.googleapis.com/auth/drive"]
creds = Credentials.from_service_account_info(creds_dict, scopes=scope)
client = gspread.authorize(creds)

# 2. Sheet nomini shu yerga yozing. Aynan shu nom bo‘lishi shart
book = client.open("Hisobim V2") 
sheet = book.worksheet("Tranzaksiya") # <-- ANIQ SHU NOM
def get_hisoblar_list():
    return sheet.row_values(1)[1:]

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    hisobar = get_hisoblar_list()
    balans_dict = {h: 0 for h in hisobar}
    await update.message.reply_text("Bot ishga tushdi ✅")

async def daromad(update: Update, context: ContextTypes.DEFAULT_TYPE):
    try:
        summa = context.args[0]
        izoh = " ".join(context.args[1:]) if len(context.args) > 1 else "-"
        data = [datetime.now().strftime("%Y-%m-%d %H:%M"), "Daromad", summa, izoh]
        print(f"Sheetga yozilyapti: {data}") # Log uchun
        sheet.append_row(data)
        await update.message.reply_text(f"✅ {summa} so'm daromad yozildi")
    except Exception as e:
        print(f"XATO: {e}") # Xato log’da chiqadi
        await update.message.reply_text(f"❌ Xato: {e}")

async def xarajat(update: Update, context: ContextTypes.DEFAULT_TYPE):
    try:
        summa = context.args[0]
        izoh = " ".join(context.args[1:]) if len(context.args) > 1 else "-"
        data = [datetime.now().strftime("%Y-%m-%d %H:%M"), "Xarajat", summa, izoh]
        sheet.append_row(data)
        await update.message.reply_text(f"✅ {summa} so'm xarajat yozildi")
    except Exception as e:
        print(f"XATO: {e}")
        await update.message.reply_text(f"❌ Xato: {e}")

# 3. Muhimi: run_polling() eng oxirida turadi
app = Application.builder().token(TOKEN).build()
app.add_handler(CommandHandler("start", start))
app.add_handler(CommandHandler("daromad", daromad))
app.add_handler(CommandHandler("xarajat", xarajat))
app.run_polling() # Eng oxirgi qator
